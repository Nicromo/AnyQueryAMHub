# Copy to oauth.env (not committed). Used by backend on startup.

TIME_BASE_URL=https://time.tbank.ru
APP_HOST=127.0.0.1
APP_PORT=8790

# OAuth app from TiMe: Integrations → OAuth 2.0 Applications
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
# Must match Callback URL registered in TiMe (one line, no quotes)
OAUTH_REDIRECT_URI=http://127.0.0.1:8790/oauth/callback

# Optional: skip OAuth and use Personal Access Token from TiMe profile.
# Если задан — активна только эта учётка; переключатель нескольких TiMe-логинов в UI отключён.
TIME_PERSONAL_ACCESS_TOKEN=

# --- Jira (корп. инстанс, только под VPN / из разрешённой сети) ---
# Не коммитить значения. См. SECURITY.md
# JIRA_BASE_URL=https://jira3.tcsbank.ru
# JIRA_TOKEN=
# Свой JQL (по умолчанию: мои нерешённые)
# JIRA_JQL=assignee = currentUser() AND resolution = Unresolved ORDER BY updated DESC
# Если Unresolved не подходит, попробуйте: resolution is EMPTY
