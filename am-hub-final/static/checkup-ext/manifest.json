{
  "manifest_version": 3,
  "name": "AM Hub — Search Quality Checkup",
  "version": "2.0.0",
  "description": "Автопроверка качества поиска Diginetica + ИИ-рекомендации. Интеграция с AM Hub.",
  "permissions": [
    "storage",
    "tabs",
    "notifications",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://sort.diginetica.net/*",
    "https://api.groq.com/*",
    "https://*.workers.dev/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content/detector.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
