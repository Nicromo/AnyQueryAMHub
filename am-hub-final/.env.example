# ── Обязательные ──────────────────────────────────────────────────────────────
DATABASE_URL="${{Postgres.DATABASE_URL}}"
SECRET_KEY="your-secret-key-32-chars-minimum"

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TG_BOT_TOKEN="your-bot-token-from-botfather"
TG_BOT_USERNAME="your_bot_username"
ALLOWED_TG_IDS="your-telegram-user-id"
TG_NOTIFY_CHAT_ID="your-telegram-chat-id"

# ── AI ────────────────────────────────────────────────────────────────────────
GROQ_API_KEY="your-groq-api-key"
# QWEN_API_KEY=""  # опционально, fallback

# ── Airtable ──────────────────────────────────────────────────────────────────
AIRTABLE_TOKEN="your-airtable-pat"
AIRTABLE_PAT="your-airtable-pat"
AIRTABLE_BASE_ID="your-base-id"
AIRTABLE_TABLE_ID="your-table-id"
AIRTABLE_QBR_TABLE_ID="your-qbr-table-id"

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Можно вставить полный URL — система сама извлечёт ID
SHEETS_SPREADSHEET_ID="https://docs.google.com/spreadsheets/d/YOUR_ID/edit"

# ── Merchrules (вводится каждым менеджером в Settings) ────────────────────────
MERCHRULES_API_URL="https://merchrules.any-platform.ru"

# ── Ktalk (через расширение браузера) ─────────────────────────────────────────
KTALK_BASE_URL="https://tbank.ktalk.ru"
# KTALK_API_TOKEN=""   # менеджер вводит в Settings

# ── Tbank Time (через расширение браузера) ────────────────────────────────────
# TIME_API_TOKEN=""    # менеджер вводит в Settings

# ── Redis (Add Service → Redis в Railway) ─────────────────────────────────────
# REDIS_URL="${{Redis.REDIS_URL}}"

