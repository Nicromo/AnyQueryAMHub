# ─────────────────────────────────────────────────────────────────────────────
# AM Hub — переменные окружения
# Скопируй в .env и заполни значения (этот файл безопасно хранить в git)
# ─────────────────────────────────────────────────────────────────────────────

# Telegram Bot
TG_BOT_TOKEN=your_telegram_bot_token_here
TG_BOT_USERNAME=YourBotUsername
ALLOWED_TG_IDS=your_telegram_id_here

# Flask/FastAPI секрет (любая случайная строка)
SECRET_KEY=change-me-to-random-string

# Merchrules — через ЛК браузера (API-ключ опционален)
MERCHRULES_API_URL=https://merchrules.any-platform.ru
MERCHRULES_API_KEY=

# Google Sheets (Top-50) — ID таблицы и ID листа
