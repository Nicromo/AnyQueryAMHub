# ─────────────────────────────────────────────────────────────────────────────
# AM Hub — переменные окружения
# Скопируй в .env и заполни значения (этот файл безопасно хранить в git)
# ─────────────────────────────────────────────────────────────────────────────

# --- Критично для прода ------------------------------------------------------
# development | staging | production. В production enforced: SECRET_KEY,
# ALLOWED_ORIGINS, secure cookies, /docs закрыт.
ENV=development

# JWT signing key. В production обязателен любой длинный случайный secret.
SECRET_KEY=change-me-to-random-string

# CORS. В production — явный список через запятую (https://app.example.com,...).
# '*' запрещён в production (credentials + wildcard несовместимы).
ALLOWED_ORIGINS=*

# Первый админ. Если в БД нет пользователей — сидится этот. Иначе игнорируется.
# Без этих переменных система просто залогирует warning и продолжит работу.
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_NAME=Администратор

# База данных
DATABASE_URL=postgresql://user:password@localhost:5432/amhub
APP_URL=https://your-domain.example.com

# --- Интеграции --------------------------------------------------------------
# Telegram Bot
TG_BOT_TOKEN=your_telegram_bot_token_here
TG_BOT_USERNAME=YourBotUsername
ALLOWED_TG_IDS=your_telegram_id_here

# Merchrules — через ЛК браузера (API-ключ опционален)
MERCHRULES_API_URL=https://merchrules.any-platform.ru
MERCHRULES_API_KEY=

# Google Sheets (Top-50) — ID таблицы и ID листа
SHEETS_SPREADSHEET_ID=1baqs2xGFZNxCuAwTfuDiE52KXIaLaKtuZzcSN4lce3M
SHEETS_TOP50_GID=374545260

# --- Мониторинг (опционально) ------------------------------------------------
SENTRY_DSN=
